		#interrupt-cells = <1>;
		interrupt-map-mask = <0 0 0 7>;
//		interrupt-map-mask = <0xffffffff 0x0>;
		interrupt-map = <0 0 0 1 &pcie0_intc 1>, /* INT A */
				<0 0 0 2 &pcie0_intc 2>, /* INT B */
				<0 0 0 3 &pcie0_intc 3>, /* INT C */
				<0 0 0 4 &pcie0_intc 4>; /* INT D */
		pcie0_intc: interrupt-controller {
			interrupt-controller;
			#address-cells = <0>;
			#interrupt-cells = <1>;
		};
	};
	pcie1: pcie@f4325800 {
		compatible = "cortina-access,mercury-pcie";
		reg = <0x0 0xf4325800 0x0 0x00000800>,
		      <0x0 0xb0000000 0x0 0x00001000>,
		      <0x0 0xb0001000 0x0 0x00002000>,
		      <0x0 0xb0300000 0x0 0x00100000>,
		      <0x0 0xf4710000 0x0 0x0000FFFC>;
		reg-names = "glbl_regs", "rc_dbi", "config", "iatu","serdes_phy";

		resets = <&block_rst1 PCI1_RESET>, <&dphy_rst PHY_S1_PCIE_RESET>;
		reset-names = "core_reset", "phy_reset";

		phys = <&s1_pcie_phy0>, <&s1_pcie_phy1>;
		phy-names = "pcie-phy0", "pcie-phy1";

		reset-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
		ready-time = /bits/ 16 <200>;

		#address-cells = <3>;
		#size-cells = <2>;

		device_type = "pci";
		bus-range = <0x0 0xff>;
		ranges = <0x81000000 0 0          0 0xb0003000 0 0x00010000
			/* downstream I/O */
			/* 0xb0300000 - 0xb03fffff reserved for controller */
			0x82000000 0 0xb0400000 0 0xb0400000 0 0x0fc00000>;
			/* non-prefetchable memory */

		id = <1>;
		num-viewport = <1>;
		num-lanes = <2>;
		clocks = <&gate_pcie1_clk>;
		//iommus = <&pcie1_atu>;

		interrupt-parent = <&gic>;
		interrupts = <GIC_SPI IRQ_GLB_PCIE1_GIC0 IRQ_TYPE_LEVEL_HIGH>,
					/* controller interrupt */
					<GIC_SPI IRQ_GLB_PCIE1_GIC1 IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI IRQ_GLB_PCIE1_GIC2 IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI IRQ_GLB_PCIE1_GIC3 IRQ_TYPE_LEVEL_HIGH>;

		irq-affinity = <1>;  /*RTK wifi. Bound to CPU1. */

		status = "disabled";
