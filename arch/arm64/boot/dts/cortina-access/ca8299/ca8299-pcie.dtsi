#include <dt-bindings/gpio/gpio.h>
/ {

/* Synopsis Designware PCIe interface */
	/* explained in Documentation/devicetree/bindings/pci/ca77xx-pcie.txt */
	//pcie0: pcie@f4325080 {
	pcie0: pcie@f4325000 {
		compatible = "cortina-access,mercury-pcie";
		reg = <0x0 0xf4325000 0x0 0x00000800>,
		      <0x0 0xa0000000 0x0 0x00001000>,
		      <0x0 0xa0001000 0x0 0x00002000>,
		      <0x0 0xa0300000 0x0 0x00100000>,
		      <0x0 0xf4700000 0x0 0x0000FFFC>;
		reg-names = "glbl_regs", "rc_dbi", "config", "iatu","serdes_phy";

		resets = <&block_rst1 PCI0_RESET>, <&dphy_rst PHY_S0_PCIE_RESET>;
		reset-names = "core_reset", "phy_reset";

		phys = <&s0_pcie_phy0>, <&s0_pcie_phy1>;
		phy-names = "pcie-phy0", "pcie-phy1";

		reset-gpios = <&gpio0 4 GPIO_ACTIVE_LOW>;
		ready-time = /bits/ 16 <200>;

		#address-cells = <3>;
		#size-cells = <2>;

		device_type = "pci";
		bus-range = <0x0 0xff>;
		ranges = <0x81000000 0 0          0 0xa0003000 0 0x00010000
			/* downstream I/O */
			/* 0xa0300000 - 0xa03fffff reserved for controller */
			0x82000000 0 0xa0400000 0 0xa0400000 0 0x0fc00000>;
			/* non-prefetchable memory */

		id = <0>;
		num-viewport = <1>;
		num-lanes = <2>;
		clocks = <&gate_pcie0_clk>;
		//iommus = <&pcie0_atu>;

		interrupt-parent = <&gic>;
		interrupts = <GIC_SPI IRQ_GLB_PCIE0_GIC0 IRQ_TYPE_LEVEL_HIGH>,
					/* controller interrupt */
					<GIC_SPI IRQ_GLB_PCIE0_GIC1 IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI IRQ_GLB_PCIE0_GIC2 IRQ_TYPE_LEVEL_HIGH>,
					<GIC_SPI IRQ_GLB_PCIE0_GIC3 IRQ_TYPE_LEVEL_HIGH>;

		irq-affinity = <1>;  /*RTK wifi. Bound to CPU1. */

		status = "disabled";
		/* Serdes PHY parameters */
		serdes-cfg-verA = "revA v0.7 (2025.02.19)";
		serdes-cfg-dataA =
					<0x70B8 0x08f0>,
					<0x8180 0x40c1>,
					<0x9180 0x40c1>,
